API_PORT=4000
WEB_PUBLIC_API_BASE=http://localhost:4000
OVERLAY_PUBLIC_API_BASE=http://localhost:4000
DATABASE_URL=${DATABASE_URL}
QUEUE_MODE=in_memory
WORKER_ID=worker-local
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_STALE_LOCK_MS=300000
MAX_RETRY_COUNT=5
NODE_ENV=development
APP_ENV=local
REJECT_DEFAULT_MOCK_TOKENS_IN_PRODUCTION=true
MOCK_ADMIN_TOKEN=local-admin-placeholder
MOCK_INTERNAL_TOKEN=local-internal-placeholder
MOCK_OVERLAY_TOKEN=local-overlay-placeholder
OVERLAY_PUBLIC_TOKEN=local-overlay-placeholder
IRIS_CORE_API_URL=http://localhost:4100
IRIS_CORE_SHARED_SECRET=change-me-iris-core-secret
IRIS_CORE_TIMEOUT_MS=3000
YOUTUBE_CONNECTOR_MODE=mock
YOUTUBE_CREDENTIAL_SOURCE=local_env
YOUTUBE_STREAM_RECONNECT_MAX_ATTEMPTS=5
YOUTUBE_LIST_FALLBACK_MIN_POLLING_MS=1000
YOUTUBE_API_KEY=
YOUTUBE_OAUTH_TOKEN=
