{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CRIPTO-TIP CI Safe Failure Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "repository",
    "workflow_name",
    "check_name",
    "job_name",
    "head_sha",
    "base_sha",
    "run_id",
    "job_id",
    "event_name",
    "branch",
    "command_class",
    "package_scope",
    "working_directory",
    "phase",
    "exit_code",
    "result",
    "safe_reason_code",
    "raw_log_required",
    "raw_log_allowed",
    "product_code_failure",
    "external_runner_failure",
    "metadata_limited",
    "same_head_required_checks_passed",
    "next_safe_action",
    "created_at"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "repository": { "type": "string" },
    "workflow_name": { "type": "string" },
    "check_name": { "type": "string" },
    "job_name": { "type": "string" },
    "head_sha": { "type": "string" },
    "base_sha": { "type": "string" },
    "run_id": { "type": "string" },
    "job_id": { "type": "string" },
    "event_name": { "type": "string" },
    "branch": { "type": "string" },
    "command_class": { "type": "string" },
    "package_scope": { "type": "string" },
    "working_directory": { "type": "string" },
    "phase": { "type": "string" },
    "exit_code": { "type": "number" },
    "result": { "enum": ["success", "failure", "not_run"] },
    "safe_reason_code": {
      "enum": [
        "typescript_external_runner_failure",
        "pnpm_test_failed_safe_summary",
        "pnpm_typecheck_passed_but_test_failed",
        "pnpm_typecheck_failed_safe_summary",
        "safe_artifact_missing_for_failed_ci",
        "workflow_metadata_mismatch",
        "required_check_name_mismatch",
        "wrong_working_directory",
        "product_code_failure",
        "external_runner_failure",
        "raw_log_required_but_forbidden",
        "same_head_required_checks_all_pass",
        "same_head_required_checks_not_all_pass",
        "quality_gate_pass_but_required_check_failed",
        "metadata_limited_external_blocked"
      ]
    },
    "raw_log_required": { "type": "boolean" },
    "raw_log_allowed": { "const": false },
    "product_code_failure": { "type": "boolean" },
    "external_runner_failure": { "type": "boolean" },
    "metadata_limited": { "type": "boolean" },
    "same_head_required_checks_passed": { "type": "boolean" },
    "next_safe_action": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "not": {
    "anyOf": [
      { "required": ["raw_log"] },
      { "required": ["raw_logs"] },
      { "required": ["stdout"] },
      { "required": ["stderr"] },
      { "required": ["stack_trace"] },
      { "required": ["file_contents"] },
      { "required": ["dependency_tree"] }
    ]
  }
}
