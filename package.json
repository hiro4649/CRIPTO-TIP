{
  "name": "cripto-tip",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "ensure:pnpm": "corepack enable && corepack pnpm install",
    "lint": "corepack pnpm -r --workspace-concurrency=1 lint",
    "typecheck": "corepack pnpm -r --workspace-concurrency=1 typecheck",
    "test": "vitest run packages/shared apps/api apps/overlay apps/web",
    "dev:web": "corepack pnpm --filter @cripto-tip/web dev",
    "dev:api": "corepack pnpm --filter @cripto-tip/api dev",
    "dev:overlay": "corepack pnpm --filter @cripto-tip/overlay dev",
    "evidence:render": "node scripts/render-pr-evidence.mjs --input .codex/evidence-pack.json --output docs/pr-evidence-single-source-of-truth.md",
    "evidence:validate": "node scripts/validate-evidence-freshness.mjs",
    "evidence:test-summary": "node scripts/write-test-summary.mjs",
    "evidence:check-placeholders": "node scripts/check-evidence-placeholders.mjs",
    "quality:self-protection": "node scripts/check-quality-gate-self-protection.mjs"
  },
  "devDependencies": {
    "@cripto-tip/shared": "file:packages/shared",
    "@fastify/websocket": "^11.2.0",
    "@types/node": "^22.15.30",
    "@types/pg": "8.20.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "fastify": "^5.8.5",
    "pg": "8.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3",
    "viem": "2.52.0",
    "vitest": "^4.1.8",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  }
}
